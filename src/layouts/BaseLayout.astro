---
// Component Imports
import MainHead from '../components/MainHead.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Player from '../components/Player.jsx';
import loadmg from '../../public/logo2sm.png';
import { Image } from 'astro:assets';
import { ClientRouter } from 'astro:transitions';

interface Props {
	title?: string | undefined;
	description?: string | undefined;
}

const { title, description } = Astro.props;
---

<html lang="en">
	<head>
		<MainHead title={title} description={description} />
		<ClientRouter />
	</head>
	<body>
		<div id="loaddiv" class="loaddiv" transition:persist="loader-wrapper">
			<div id="loader" class="logoload"></div>
			<Image id="logoload-img" src={loadmg} alt="logospn" class="logoload1"/>
			<div class="ricld"></div>
			<div class="ricld"></div>
			<div class="ricld"></div>
		</div>

		<div id="contents2" class="stack backgrounds">
			<div class="ricsn">❅</div>
			<div class="ricsn">❅</div>
			<div class="ricsn">❆</div>
			<div class="ricsn">❄</div>
			<div class="ricsn">❅</div>
			<div class="ricsn">❆</div>
			<div class="ricsn">❄</div>
			<div class="ricsn">❅</div>
			<div class="ricsn">❆</div>
			<div class="ricsn">❄</div>

			<div transition:persist="navigation">
				<Nav />
			</div>

			<main>
				<slot />
			</main>

			<Footer />

			<Player client:only="react" transition:persist />
		</div>

		<script>
			/**
			 * Handles the loading screen. 
			 * We only want the long 1s delay on the VERY first visit.
			 */
			function handleLoading() {
				const loaddiv = document.getElementById('loaddiv');
				const contents2 = document.getElementById('contents2');
				
				if (!loaddiv || !contents2) return;

				// If it's a page transition (not a hard reload), show content immediately
				if (window.name === "is-navigating") {
					loaddiv.style.display = "none";
					contents2.style.visibility = "visible";
					return;
				}

				// Hard reload logic
				if (document.readyState === 'complete') {
					setTimeout(() => {
						loaddiv.style.display = "none";
						contents2.style.visibility = "visible";
						window.name = "is-navigating"; // Mark as visited
					}, 1000);
				}
			}

			// Run on initial load
			window.addEventListener('load', handleLoading);

			// Logic for other media elements
			function initMediaPause() {
				const RicVideos = document.querySelectorAll("video, audio");
				RicVideos.forEach(media => {
					media.addEventListener('play', function() {
						RicVideos.forEach(other => {
							if (other !== media) {
								(other as HTMLMediaElement).pause();
								(other as HTMLMediaElement).muted = true;
							}
						});
					}, true);
				});
			}

			initMediaPause();

			// Ensure content is visible after Astro swaps pages
			document.addEventListener('astro:after-swap', () => {
				initMediaPause();
				const contents2 = document.getElementById('contents2');
				const loaddiv = document.getElementById('loaddiv');
				if (contents2) contents2.style.visibility = "visible";
				if (loaddiv) loaddiv.style.display = "none";
			});
		</script>

		<style is:global>
			/* is:global ensures styles aren't stripped during swaps */
			#contents2 {
				visibility: hidden;
			}

			.loaddiv {
				display: flex;
				width:100vw;
				height:100vh;
				align-items: center;
				justify-content: center;
				background: radial-gradient(circle, rgba(51,47,57,1) 0%, rgba(14,4,25,1) 100%);
				position:fixed;
				top:0;
				left:0;
				z-index:9990;
			}

			.logoload {
				display: flex;
				position:relative;
				width: 120px;
				height: 120px;
				border-radius: 50%;
				background: conic-gradient(#3dffc9, #f7c723, #eb0ea5, #3dffc9);
				animation: spin 0.8s linear infinite;
				box-shadow: 0px 0px 150px -75px black;
				justify-content:center;
				align-items:center;
				z-index: 9993;
			}

			.logoload::before {
				content: "";
				background-color: black;
				position: absolute;
				width: 86%;
				height: 86%;
				border-radius: 50%;
				top: 50%;
				left: 50%;
				transform: translate(-50%, -50%);
			}

			.logoload1 {
				position:absolute;
				width:120px;
				height:120px;
				z-index:9998;
			}

			@keyframes spin {
				0% { transform: rotate(0deg); }
				100% { transform: rotate(-360deg); }
			}

			.ricld {
				position:absolute;
				width: 230px;
				height: 230px;
				border-radius: 50%;
				z-index: 9997;
			}

			.ricld:nth-child(5){ border-bottom: 6px solid red; animation: spinric1 1.2s linear infinite; }
			.ricld:nth-child(4){ border-right: 6px solid blue; animation: spinric2 0.9s linear infinite; }
			.ricld:nth-child(3){ border-top: 6px solid green; animation: spinric3 1.2s linear infinite; }

			@keyframes spinric1 {
				0% { transform: rotateX(35deg) rotateY(-45deg) rotateZ(0deg); }
				100% { transform: rotateX(35deg) rotateY(-45deg) rotateZ(360deg); }
			}
			@keyframes spinric2 {
				0% { transform: rotateX(53deg) rotateY(10deg) rotateZ(0deg); }
				100% { transform: rotateX(53deg) rotateY(10deg) rotateZ(360deg); }
			}
			@keyframes spinric3 {
				0% { transform: rotateX(35deg) rotateY(45deg) rotateZ(0deg); }
				100% { transform: rotateX(35deg) rotateY(45deg) rotateZ(360deg); }
			}

			.backgrounds {
				min-height: 100vh;
				isolation: isolate;
				background:
					url('/assets/backgrounds/noise.png') top center/220px repeat,
					var(--bg-image-footer, none) bottom center/var(--bg-gradient-size, 100%) no-repeat,
					var(--bg-image-main-curves, none) top center/var(--bg-gradient-size, 100%) no-repeat,
					var(--bg-image-main, none) top center/var(--bg-gradient-size, 100%) no-repeat,
					#050505;
			}
		</style>
	</body>
</html>
